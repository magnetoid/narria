# ─── Site ──────────────────────────────────────────────────────────────────────
# Public base URL of the deployment (used for metadata / absolute links).
NEXT_PUBLIC_SITE_URL=https://narria.dotbooks.store

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Works with EITHER Supabase cloud (project Settings → API) or a self-hosted
# Supabase service (Coolify one-click). Same variables either way.
# Server code uses the service-role key; never expose it to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI (Anthropic Claude) ─────────────────────────────────────────────────────
# Leave ANTHROPIC_API_KEY blank to run on the deterministic MOCK provider — the
# entire app works end-to-end with no key and no cost. Set the key to use real Claude.
ANTHROPIC_API_KEY=

# Optional: force a provider. Auto-selects "anthropic" when a key is present, else "mock".
# NARRIA_AI_PROVIDER=mock

# Optional per-agent model overrides (defaults shown). Dial down for cost.
NARRIA_MODEL_DEFAULT=claude-opus-4-8
NARRIA_MODEL_WRITER=claude-sonnet-4-6
NARRIA_MODEL_METADATA=claude-haiku-4-5
